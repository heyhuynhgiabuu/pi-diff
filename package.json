{
  "name": "@heyhuynhgiabuu/pi-diff",
  "version": "0.6.4",
  "description": "Shiki-powered terminal diff renderer for pi \u2014 syntax-highlighted, word-level diffs in split and unified views.",
  "keywords": [
    "diff",
    "pi",
    "pi-extension",
    "pi-package",
    "shiki",
    "syntax-highlighting",
    "terminal"
  ],
  "homepage": "https://github.com/buddingnewinsights/pi-diff#readme",
  "bugs": {
    "url": "https://github.com/buddingnewinsights/pi-diff/issues"
  },
  "license": "MIT",
  "author": "huynhgiabuu",
  "repository": {
    "type": "git",
    "url": "https://github.com/buddingnewinsights/pi-diff.git"
  },
  "bin": {
    "pi-diff-review": "./dist/cli.js"
  },
  "files": [
    "dist",
    "web",
    "types",
    "!dist/**/*.test.*",
    "!dist/**/__tests__/**"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "test": "vitest run src --passWithNoTests",
    "test:watch": "vitest src --passWithNoTests"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "@earendil-works/pi-tui": "^0.79.0",
    "@shikijs/cli": "^4.0.2",
    "diff": "^7.0.0",
    "glimpseui": "^0.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@types/diff": "^7.0.2",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "main": "./dist/index.js",
  "exports": {
    "default": "./dist/index.js"
  }
}
